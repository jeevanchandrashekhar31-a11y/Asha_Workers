{
  "name": "field-agent",
  "version": "1.0.0",
  "description": "Voice-first AI agent for health workers",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "dev:all": "concurrently -n APP,AGENT -c blue,green \"node --watch server/index.js\" \"node server/agents/start-agent.js\""
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.8.0",
    "@google/adk": "^1.3.0",
    "@google/generative-ai": "^0.11.4",
    "@prisma/client": "6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "6.19.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@google/adk-devtools": "^1.3.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0"
  }
}
